mas:Color Picker=1545870783                  # colour picker
mas:Fantastical - Calendar=975937182         # calendar
mas:Googly Eyes=6743048714                   # googly eyes that follow your cursor
mas:Harvest=506189836                        # time tracking
mas:Keynote=409183694                        # presentations
mas:Lungo=1263070803                         # prevent sleep
mas:Pages=409201541                          # word processor
mas:Pixelmator Pro=1289583905                # image editor
