# Optional Homebrew entries — picked interactively by
# scripts/install-brewfile.sh. Format (one per line):
#
#   brew:<name>              # description
#   cask:<name>              # description
#   tap:<owner>/<repo>       # description
#   mas:<App Name>=<id>      # description
#
# Lines starting with # and blank lines are ignored.

# -- Taps ---------------------------------------------------------------------
tap:anomalyco/tap                            # source for opencode

# -- CLI tools ----------------------------------------------------------------
brew:agent-browser                           # browser automation CLI for AI agents
brew:anomalyco/tap/opencode                  # AI coding agent for the terminal
brew:doggo                                   # modern DNS client
brew:ffmpeg                                  # media processing
brew:imagemagick                             # image processing
brew:lazydocker                              # docker TUI
brew:lazygit                                 # git TUI
brew:mole                                    # Deep clean and optimize your Mac
brew:neovim                                  # editor

# -- Fonts --------------------------------------------------------------------
cask:font-blex-mono-nerd-font                # IBM Plex Mono (Nerd Font)
cask:font-geist-mono-nerd-font               # Geist Mono (Nerd Font)
cask:font-im-writing-nerd-font               # iA Writer Mono (Nerd Font)
cask:font-monaspice-nerd-font                # Monaspace (Nerd Font)
cask:font-sauce-code-pro-nerd-font           # Source Code Pro (Nerd Font)

# -- Apps ---------------------------------------------------------------------
cask:acorn                                   # image editor
cask:bettermouse                             # mouse customisation
cask:blender                                 # 3D creation suite
cask:choosy                                  # browser chooser
cask:cmux                                    # Ghostty-based terminal for AI coding agents
cask:codex                                   # OpenAI coding agent (CLI)
cask:docker-desktop                          # container app platform
cask:figma                                   # design tool
cask:firefox@developer-edition               # browser
cask:handbrake-app                           # video transcoding
cask:httpie-desktop                          # API client
cask:iina                                    # video player
cask:imageoptim                              # image compression
cask:jordanbaird-ice                         # menu bar manager
cask:notion-calendar                         # calendar
cask:notion                                  # notes & docs
cask:onyx                                    # macOS maintenance
cask:opencode-desktop                        # AI coding agent (desktop)
cask:podman-desktop                          # GUI for podman containers
cask:setapp                                  # subscription app bundle
cask:tower                                   # git GUI
cask:zed                                     # editor

# -- Setapp-replaceable (only install if not using Setapp) --------------------
cask:bartender                               # menu bar icon organiser — also in Setapp
cask:cleanmymac                              # disk cleaner — also in Setapp
cask:cleanshot                               # screen capture — also in Setapp
cask:pixelsnap                               # screen ruler — also in Setapp
cask:tableplus                               # database GUI — also in Setapp

